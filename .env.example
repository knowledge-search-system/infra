POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

REDIS_PORT=6379
ELASTICSEARCH_PORT=9200

SEARCH_ENGINE_CONFIG_PATH=config/configs/config.yaml

SEARCH_ENGINE_GRPC_PORT=9090
SEARCH_ENGINE_HTTP_PORT=8080

SEARCH_ENGINE_POSTGRES_DSN=postgres://postgres:postgres@postgres:5432/search_engine?sslmode=disable

SEARCH_ENGINE_REDIS_ADDR=redis:6379
SEARCH_ENGINE_REDIS_PASSWORD=

SEARCH_ENGINE_ELASTICSEARCH_ADDRESSES=http://elasticsearch:9200
SEARCH_ENGINE_ELASTICSEARCH_USERNAME=
SEARCH_ENGINE_ELASTICSEARCH_PASSWORD=

SEARCH_ENGINE_LOG_LEVEL=info

DOCUMENT_PROCESSOR_CONFIG_PATH=config/configs/config.yaml

DOCUMENT_PROCESSOR_GRPC_PORT=9091
DOCUMENT_PROCESSOR_HTTP_PORT=8081

DOCUMENT_PROCESSOR_POSTGRES_DSN=postgres://postgres:postgres@postgres:5432/document_processor?sslmode=disable

DOCUMENT_PROCESSOR_SEARCH_ENGINE_GRPC_ADDR=search-engine:9090

DOCUMENT_PROCESSOR_LOG_LEVEL=info

SEARCH_ENGINE_POSTGRES_DSN=postgres://postgres:postgres@postgres:5432/search_engine?sslmode=disable

DOCUMENT_PROCESSOR_POSTGRES_DSN=postgres://postgres:postgres@postgres:5432/document_processor?sslmode=disable